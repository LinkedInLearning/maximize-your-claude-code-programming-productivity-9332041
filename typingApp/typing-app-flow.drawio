<mxfile host="app.diagrams.net">
  <diagram name="High-Level Flow" id="highlevel">
    <mxGraphModel adaptiveColors="auto" dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title-h" value="Typing Game — High-Level Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="360" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="boot" value="App boot" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="320" y="70" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="idle" value="Idle&#10;(passage loaded)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="320" y="160" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="typing" value="Typing&#10;in progress" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="320" y="270" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="results" value="Results modal&#10;WPM / Accuracy / Time" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="300" y="380" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="finished" value="Finished passage&#10;(modal closed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="540" y="380" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e1" value="" style="endArrow=classic;html=1;" edge="1" parent="1" source="boot" target="idle">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="First keystroke" style="endArrow=classic;html=1;" edge="1" parent="1" source="idle" target="typing">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="Finishes passage" style="endArrow=classic;html=1;" edge="1" parent="1" source="typing" target="results">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" value="Next passage" style="endArrow=classic;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="results" target="idle">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="240" y="410"/>
              <mxPoint x="240" y="190"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e5" value="Close" style="endArrow=classic;html=1;" edge="1" parent="1" source="results" target="finished">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" value="Next / Restart" style="endArrow=classic;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="finished" target="idle">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="760" y="410"/>
              <mxPoint x="760" y="190"/>
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="All Interactions" id="interactions">
    <mxGraphModel adaptiveColors="auto" dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title-l" value="Typing Game — All User Interactions" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="320" y="20" width="460" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="start" value="●" style="ellipse;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;fontColor=#ffffff;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="30" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="unfocused" value="Unfocused" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="160" y="120" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s-idle" value="Idle&#10;(passage loaded)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="380" y="115" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="s-typing" value="Typing&#10;(timer running)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="640" y="115" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="s-results" value="Results Modal Open" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="640" y="320" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="s-finished" value="Finished&#10;(modal hidden)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="380" y="320" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="export-note" value="Export results&#10;(TSV download)&#10;available from any state&#10;— does not change state" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="500" width="200" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="t-boot" value="boot / loadPassage(0)" style="endArrow=classic;html=1;" edge="1" parent="1" source="start" target="s-idle">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="120" y="135"/>
              <mxPoint x="120" y="145"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="t-focus" value="Click viewport (focus)" style="endArrow=classic;html=1;" edge="1" parent="1" source="unfocused" target="s-idle">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t-blur" value="Blur" style="endArrow=classic;html=1;exitX=0;exitY=0.25;exitDx=0;exitDy=0;entryX=1;entryY=0.75;entryDx=0;entryDy=0;" edge="1" parent="1" source="s-idle" target="unfocused">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t-firstkey" value="First printable key&#10;(startTimeMs set)" style="endArrow=classic;html=1;" edge="1" parent="1" source="s-idle" target="s-typing">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t-typeloop" value="Printable key (correct → done)&#10;Printable key (wrong → err)&#10;Backspace (revert caret)" style="endArrow=classic;html=1;exitX=0.75;exitY=0;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="s-typing" target="s-typing">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="760" y="70"/>
              <mxPoint x="680" y="70"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="t-finish" value="caretIndex ≥ length&#10;finishPassage()&#10;saves to localStorage" style="endArrow=classic;html=1;" edge="1" parent="1" source="s-typing" target="s-results">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t-modal-next" value="Click &quot;Next passage&quot; (modal)" style="endArrow=classic;html=1;" edge="1" parent="1" source="s-results" target="s-idle">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t-modal-close" value="Click &quot;Close&quot;" style="endArrow=classic;html=1;" edge="1" parent="1" source="s-results" target="s-finished">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t-fin-next" value="Click &quot;Next passage&quot; / &quot;Restart&quot;" style="endArrow=classic;html=1;" edge="1" parent="1" source="s-finished" target="s-idle">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="t-idle-restart" value="Restart / Next" style="endArrow=classic;html=1;exitX=0.25;exitY=0;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="s-idle" target="s-idle">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="420" y="70"/>
              <mxPoint x="500" y="70"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="t-typing-reset" value="Restart / Next&#10;(skip / reset)" style="endArrow=classic;html=1;dashed=1;" edge="1" parent="1" source="s-typing" target="s-idle">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
